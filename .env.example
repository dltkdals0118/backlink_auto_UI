# OpenAI
OPENAI_API_KEY=sk-...여기에_실제_키_입력
# 콘텐츠(EEAT 글) 생성 모델 — gpt-4o
OPENAI_MODEL=gpt-4o
# 캡차 이미지 인식(비전) 모델 — 정확도 높은 gpt-4o
OPENAI_VISION_MODEL=gpt-4o

# 대상 글쓰기 폼 URL (CLI --url 로 덮어쓸 수 있음)
TARGET_URL=http://seouljasu.com/bbs/write.php?bo_table=qa

# 브라우저 표시 여부 (true=숨김)
HEADLESS=true

# 캡차 재시도 횟수
MAX_CAPTCHA_RETRIES=5

# 요청 간 최소 딜레이(초)
REQUEST_DELAY=2

# Windows에서 tesseract.exe 경로 (PATH에 없을 때만 지정)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# 안드로이드 IP 변경(ADB) 설정
# ADB_CMD=C:\platform-tools\adb.exe
IP_OFF_WAIT=4
IP_ON_WAIT=5
IP_VERIFY_TIMEOUT=40
